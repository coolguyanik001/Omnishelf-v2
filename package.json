{
  "name": "omnishelf",
  "version": "2.0.0",
  "private": true,
  "description": "Cross-platform document reader PWA — Web · Desktop · Mobile",
  "main": "electron/main.js",
  "scripts": {
    "dev":         "vite",
    "build":       "vite build",
    "preview":     "vite preview",

    "share":       "node scripts/share.js",

    "electron:dev":   "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:mac":   "vite build && electron-builder --mac",
    "electron:linux": "vite build && electron-builder --linux",

    "cap:init":    "cap init OmniShelf com.omnishelf.app --web-dir dist",
    "cap:android": "vite build && cap copy android && cap open android",
    "cap:sync":    "cap sync",
    "apk:debug":   "vite build && cap sync android && cd android && ./gradlew assembleDebug",
    "apk:release": "vite build && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/core":    "^5.7.0",
    "dexie":             "^3.2.4",
    "jszip":             "^3.10.1",
    "mammoth":           "^1.6.0",
    "pdfjs-dist":        "^3.11.174"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently":         "^8.2.2",
    "electron":             "^28.3.0",
    "electron-builder":     "^24.9.1",
    "react":                "^18.2.0",
    "react-dom":            "^18.2.0",
    "tailwindcss":          "^3.4.1",
    "vite":                 "^5.1.4",
    "wait-on":              "^7.2.0"
  },
  "build": {
    "appId":       "com.omnishelf.app",
    "productName": "OmniShelf",
    "icon":        "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target":   [{ "target": "dmg", "arch": ["arm64","x64"] }],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage","deb"]
    },
    "nsis": {
      "oneClick":           false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon":      "assets/icon.ico",
      "installerHeaderIcon":"assets/icon.ico"
    }
  }
}
